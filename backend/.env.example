PORT=5000

# Local MongoDB (for running on your own PC)
MONGODB_URI=mongodb://127.0.0.1:27017/contract_management

# MongoDB Atlas (for cloud deployment on Render) — replace YOUR_PASSWORD with your Atlas password
# MONGODB_URI=mongodb+srv://tesca-admin:YOUR_PASSWORD@cluster0.dhqvcof.mongodb.net/contract_management?appName=Cluster0

JWT_SECRET=replace_this_with_a_strong_random_secret
RENEWAL_CHECK_INTERVAL_MS=3600000
RENEWAL_ALERT_DAYS=15
RENEWAL_EXTENSION_MONTHS=12
NODE_ENV=development
